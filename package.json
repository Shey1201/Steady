{
  "name": "steady-root",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "tauri": "npm --workspace @steady/desktop run tauri --",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.10",
    "@ai-sdk/openai": "^3.0.19",
    "@prisma/client": "^7.3.0",
    "ai": "^6.0.49",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@vercel/node": "^5.5.27",
    "typescript": "^5.9.3",
    "vitest": "^2.1.5"
  }
}
